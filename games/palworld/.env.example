# Copied to /etc/game-server/.env by the bake script.

SERVER_NAME=My Palworld
SERVER_DESCRIPTION=On-demand Palworld server
SERVER_PASSWORD=changeme
# ADMIN_PASSWORD is used by the watchdog's probe.sh to talk to the REST API.
# It must be set — without it the watchdog can't count players.
ADMIN_PASSWORD=changeme-admin
MAX_PLAYERS=32
COMMUNITY=false

# QUERY_PORT not used for Palworld — the watchdog dispatches to probe.sh which
# uses the REST API for player counts (Palworld doesn't respond to A2S).
