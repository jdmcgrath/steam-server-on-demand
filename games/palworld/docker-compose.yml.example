services:
  palworld:
    image: thijsvanloef/palworld-server-docker:latest
    container_name: palworld
    restart: unless-stopped
    stop_grace_period: 90s
    ports:
      - "8211:8211/udp"        # game (player connections)
      # Steam query port (27015) deliberately not exposed:
      # Palworld's dedicated server doesn't reliably respond to A2S queries,
      # so the watchdog uses the REST API for player counting instead
      # (see games/palworld/probe.sh). The REST API on 8212 stays internal —
      # the upstream image's README explicitly says DO NOT publish 8212.
    environment:
      - SERVER_NAME=${SERVER_NAME:-Palworld On-Demand}
      - SERVER_DESCRIPTION=${SERVER_DESCRIPTION:-On-demand Palworld server}
      - SERVER_PASSWORD=${SERVER_PASSWORD}
      - ADMIN_PASSWORD=${ADMIN_PASSWORD}
      - MAX_PLAYERS=${MAX_PLAYERS:-32}
      - COMMUNITY=${COMMUNITY:-false}        # true = list in Steam community browser
      - REST_API_ENABLED=true                # required for the watchdog's probe.sh
      - REST_API_PORT=8212
      - PUID=1000
      - PGID=1000
    volumes:
      # Persistent block volume mounted on the VM at /mnt/saves — Palworld's
      # save data lives here.
      - /mnt/saves:/palworld/Pal/Saved
      # Named volume on the VM's root disk — captured by the snapshot so the
      # game binaries don't redownload every boot.
      - palworld-game:/palworld

volumes:
  palworld-game:
