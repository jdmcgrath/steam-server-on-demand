# Copied to /etc/game-server/.env by the bake script.

SERVER_NAME=My Valheim
WORLD_NAME=Dedicated
SERVER_PASSWORD=changeme123

# IMPORTANT: must be `true` for the idle watchdog to work.
# Valheim only responds to A2S queries (which the watchdog uses to count
# players) when registered as a public server. With SERVER_PUBLIC=false the
# server still requires the password to join, but the watchdog can't see
# players and will eventually shut the VM down regardless.
SERVER_PUBLIC=true

# A2S query lives on the port immediately after the game port (2456 + 1).
QUERY_PORT=2457
