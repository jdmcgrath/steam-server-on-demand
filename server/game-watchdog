#!/usr/bin/env bash
#
# Idle watchdog. Polls a player-count probe every minute; while any player is
# connected, the idle timer is held at zero. After IDLE_MINUTES of zero
# players, performs a graceful shutdown and notifies the Worker (which
# deletes the Hetzner VM).
#
# Probe dispatch:
#   1. If /etc/game-server/probe.sh exists and is executable, run it.
#      It must print the player count to stdout and exit 0 on success.
#      Games that don't speak A2S (like Palworld → REST API) provide their own.
#   2. Otherwise, fall back to the built-in Steam A2S probe against QUERY_PORT.
#      Works for Enshrouded, Valheim, V Rising, and most Source-engine games.
#
# Required runtime files on the host:
#   /etc/game-server/worker-url   contains the Worker /api/cleanup URL
#   /etc/game-server/secret       shared secret matching WATCHDOG_SECRET in Worker
#
set -euo pipefail

WORKER_URL="$(cat /etc/game-server/worker-url)"
SECRET="$(cat /etc/game-server/secret)"
IDLE_MINUTES="${IDLE_MINUTES:-60}"
QUERY_PORT="${QUERY_PORT:-15637}"
POLL_INTERVAL="${POLL_INTERVAL:-60}"
PROBE_SCRIPT="${PROBE_SCRIPT:-/etc/game-server/probe.sh}"

a2s_player_count() {
  python3 - "$QUERY_PORT" <<'PYEOF'
import socket, sys
port = int(sys.argv[1])
s = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
s.settimeout(3.0)
payload = b"\xff\xff\xff\xffTSource Engine Query\x00"
try:
    s.sendto(payload, ("127.0.0.1", port))
    data, _ = s.recvfrom(1400)
    # Steam may respond with a challenge (0x41) — resend with challenge appended.
    if len(data) >= 5 and data[4] == 0x41:
        s.sendto(payload + data[5:9], ("127.0.0.1", port))
        data, _ = s.recvfrom(1400)
    # Expect A2S_INFO response (0x49).
    if len(data) < 6 or data[4] != 0x49:
        sys.exit(2)
    # Skip 4 null-terminated strings (name, map, folder, game) + 2-byte appid.
    idx = 6
    for _ in range(4):
        idx = data.index(b"\x00", idx) + 1
    idx += 2
    print(data[idx])  # player count
except Exception:
    sys.exit(1)
PYEOF
}

get_player_count() {
  if [ -x "$PROBE_SCRIPT" ]; then
    "$PROBE_SCRIPT"
  else
    a2s_player_count
  fi
}

if [ -x "$PROBE_SCRIPT" ]; then
  probe_kind="custom probe ($PROBE_SCRIPT)"
else
  probe_kind="A2S query on port $QUERY_PORT"
fi

idle_since=$(date +%s)
logger "game-watchdog: starting (idle limit ${IDLE_MINUTES}m, poll ${POLL_INTERVAL}s, $probe_kind)"

while true; do
  sleep "$POLL_INTERVAL"

  if count=$(get_player_count 2>/dev/null); then
    if [ "$count" -gt 0 ]; then
      idle_since=$(date +%s)
      logger "game-watchdog: ${count} player(s) online, idle timer reset"
      continue
    fi
    state="0 players"
  else
    state="query failed"
  fi

  idle_for_min=$(( ($(date +%s) - idle_since) / 60 ))
  logger "game-watchdog: ${state}, idle for ${idle_for_min}m / ${IDLE_MINUTES}m"

  if [ "$idle_for_min" -ge "$IDLE_MINUTES" ]; then
    logger "game-watchdog: idle threshold reached, shutting down"
    cd /etc/game-server && docker compose down
    sleep 30
    curl -fsS -X POST "$WORKER_URL" \
      -H "Authorization: Bearer ${SECRET}" \
      -d "{\"server\":\"$(hostname)\"}" || true
    shutdown -h now
    exit 0
  fi
done
